@model List<FashionShop.Models.SanPham>
@{
    ViewBag.Title = "Danh sách sản phẩm theo danh mục";
    Layout = "~/Views/Shared/_LayoutPage_Main.cshtml";
}

@section LibraryCSS{
    <link href="@Url.Content("~/assets/css/pages/products.css")" rel="stylesheet" />
}

@section LibraryJS{
    <script src="@Url.Content("/assets/js/pages/products.js")"></script>
    @*<script>
            document.getElementById('nextPage').addEventListener('click', (event) => {
                var currentPage = @ViewBag.Page;
                var nextPage = currentPage + 1;

                if (nextPage > 0 && nextPage <= @ViewBag.NoOfPages) {
                    var link = '@Url.Action("List", "Product")?page=' + nextPage;
                    document.getElementById('nextPage').setAttribute('href', link)
                }
            })
            document.getElementById('prevPage').addEventListener('click', (event) => {
                 var currentPage = @ViewBag.Page;
                 var prevPage = currentPage - 1;

                 if (prevPage > 0 && prevPage <= @ViewBag.NoOfPages) {
                     var link = '@Url.Action("List", "Product")?page=' + prevPage;
                     document.getElementById('prevPage').setAttribute('href', link)
                 }
            })
        </script>*@
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dark">Trang chủ</a>
        </li>
        <li class="breadcrumb-item active text-danger">Tất cả sản phẩm</li>
    </ol>
</nav>

<div class="row">
    <aside class="col-lg-3 d-none d-lg-block">
        @Html.Action("CategoryPartial", "Home")
        @Html.Action("BrandPartial", "Home")
    </aside>

    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h5 class="fw-bold m-0 text-uppercase">Tất cả sản phẩm</h5>
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center gap-2 d-none d-md-flex">
                    <span class="small text-muted text-nowrap">Sắp xếp theo:</span>
                    <select class="form-select form-select-sm" style="width: 150px">
                        <option selected>Mặc định</option>
                        <option>Giá tăng dần</option>
                        <option>Giá giảm dần</option>
                        <option>Mới nhất</option>
                    </select>
                </div>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary active" id="gridViewBtn">
                        <i class="fa-solid fa-grip"></i> Lưới
                    </button>
                    <button class="btn btn-outline-secondary" id="listViewBtn">
                        <i class="fa-solid fa-list"></i> Danh sách
                    </button>
                </div>
            </div>
        </div>

        <div id="productWrapper" class="row g-2">
            @if (Model.Count != 0)
            {
                foreach (var item in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3 product-item">
                        <div class="product-card border p-2 text-center h-100">
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2">New</span>
                            <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">@string.Format("-{0}%", item.KhuyenMai * 100)</span>

                            <div class="favorite-badge">
                                <i class="fa-regular fa-heart"></i>
                            </div>

                            <a href="@Url.Action("Details", "Product", new { maSanPham = item.MaSanPham})"
                               class="stretched-link text-decoration-none text-dark"></a>

                            <div class="product-img-wrapper">
                                <img src="@Url.Content("~/assets/img/")@item.AnhDaiDien" alt="Product Name" />
                            </div>

                            <div class="product-info mt-auto text-center">
                                <h6 class="text-truncate px-1 mb-1 fw-bold">@item.TenSanPham</h6>

                                <p class="product-description d-none small text-muted px-1">
                                    @item.MoTaSanPham
                                </p>

                                <div class="price-box mb-1 px-1">
                                    <span class="text-decoration-line-through text-muted small me-2">@string.Format("{0:#,##0}đ", item.GiaSanPham)</span>
                                    @if (item.KhuyenMai != 0)
                                    {
                                        <div class="text-danger fw-bold">@string.Format("{0:#,##0}đ", item.GiaSanPham - (item.GiaSanPham * item.KhuyenMai))</div>
                                    }
                                </div>

                                <div class="rating-sold d-flex align-items-center justify-content-center small px-1">
                                    <div class="text-warning me-2">
                                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i>
                                    </div>
                                    <span class="text-muted border-start ps-2">Đã bán 0</span>
                                </div>

                                <div class="mt-3 px-1 d-none btn-buy-wrapper">
                                    <button class="btn btn-danger btn-sm w-100">
                                        <i class="fa-solid fa-cart-plus"></i> Mua ngay
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled"><a class="page-link" href="#">Prev</a></li>
                        @for (int i = 0; i < ViewBag.NoOfPages; i++)
                        {
                            if ((i + 1) == ViewBag.Page)
                            {
                                <li class="page-item active">
                                    <a class="page-link bg-danger border-danger" href="@Url.Action("List", "Product", new { maLoaiSanPham = ViewBag.MaLoaiSanPham, page = (i + 1)})">@(i+1)</a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link text-dark" href="@Url.Action("GetInfoAboutProductType", "ProductType", new { maLoaiSanPham = ViewBag.MaLoaiSanPham, page = (i + 1)})">@(i+1)</a>
                                </li>
                            }
                        }
                        <li class="page-item"><a class="page-link text-dark" href="#">Next</a></li>
                    </ul>
                </nav>
            }
            else
            {
                <div class="empty-state text-center py-5 w-100">
                    <div class="mb-4">
                        <i class="fa-solid fa-box-open text-muted" style="font-size: 80px; opacity: 0.3;"></i>
                    </div>
                    <h4 class="fw-bold">Hì, không tìm thấy sản phẩm nào!</h4>
                    <p class="text-muted">Có vẻ như danh mục này hiện chưa có sản phẩm hoặc đã hết hàng.</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-danger rounded-pill px-4 mt-3">
                        Tiếp tục mua sắm
                    </a>
                </div>
            }
        </div>
    </div>
</div>
