<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fashion Shop - Thế giới thời trang của bạn</title>
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/assets/icons/icon16.ico")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/font-awesome/css/all.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/swiper/swiper-bundle.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/toastr.js/toastr.min.css")" />

    @RenderSection("LibraryCSS", required: false)

</head>
<body>
    @Html.Action("Header", "Common")

    @{
        Html.RenderPartial("_PartialPage_MenuNavigation");
    }

    @RenderSection("Banner", required: false)

    <main class="container my-4 main-content">
        @RenderBody()
    </main>

    @{
        Html.RenderPartial("_PartialPage_Footer");
    }

    <div class="modal fade"
         id="disclaimerModal"
         tabindex="-1"
         aria-labelledby="disclaimerModalLabel"
         aria-hidden="true"
         data-bs-backdrop="static"
         data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning text-dark border-0 justify-content-center">
                    <h5 class="modal-title fw-bold text-center" id="disclaimerModalLabel">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>THÔNG BÁO QUAN TRỌNG
                    </h5>
                </div>
                <div class="modal-body p-4">
                    <p>Chào mừng bạn đến với <strong>Fashion Shop</strong>.</p>
                    <p class="mb-3 text-justify">
                        Đây là một <strong>dự án cá nhân phục vụ mục đích học tập</strong> và nghiên cứu về
                        lập trình web.
                    </p>
                    <ul class="small text-muted mb-4">
                        <li>Tất cả hình ảnh và thông tin sản phẩm đều mang tính chất minh họa.</li>
                        <li>
                            Chúng tôi <strong>không kinh doanh, không giao dịch</strong> và không thu thập thanh
                            toán thực tế trên website này.
                        </li>
                        <li>Website không thuộc quản lý của bất kỳ doanh nghiệp thương mại nào.</li>
                    </ul>
                    <div class="alert alert-light border-start border-warning border-4 py-2 small text-center">
                        Việc bạn tiếp tục sử dụng website đồng nghĩa với việc bạn xác nhận đã hiểu rõ mục đích
                        phi thương mại của dự án này.
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button"
                            class="btn btn-danger w-100 fw-bold py-2"
                            id="btnAcceptDisclaimer">
                        TÔI ĐÃ HIỂU VÀ XÁC NHẬN
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="@Url.Content("~/lib/bootstrap/js/bootstrap.bundle.min.js")"></script>
    <script src="@Url.Content("~/lib/swiper/swiper-bundle.min.js")"></script>
    <script src="@Url.Content("~/lib/jquery/jquery.min.js")"></script>
    <script src="@Url.Content("~/lib/jquery-validate/jquery.validate.min.js")"></script>
    <script src="@Url.Content("~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js")"></script>
    <script src="@Url.Content("~/lib/toastr.js/toastr.min.js")"></script>
    <script src="~/assets/javascript/base.js"></script>
    @Html.Partial("_PartialPage_Notifications")
    @RenderSection("LibraryJS", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const hasAccepted = sessionStorage.getItem("disclaimerAccepted");

            if (!hasAccepted) {
                var myModal = new bootstrap.Modal(document.getElementById("disclaimerModal"));
                myModal.show();

                document.getElementById("btnAcceptDisclaimer").addEventListener("click", function () {
                    sessionStorage.setItem("disclaimerAccepted", "true");
                    myModal.hide();
                });
            }
        });
    </script>
</body>
</html>
