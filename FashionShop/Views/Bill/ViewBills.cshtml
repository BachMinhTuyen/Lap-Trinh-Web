@model List<FashionShop.Models.HoaDon>
@{
    ViewBag.Title = "Đơn Hàng";
    Layout = "~/Views/Shared/_LayoutPage_Main.cshtml";
}

@section LibraryCSS {
    <link href="@Url.Content("~/assets/css/pages/order-history.css")" rel="stylesheet" />
}
@section LibraryJS {

}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-muted">Trang chủ</a>
        </li>
        <li class="breadcrumb-item active text-danger fw-bold">Lịch sử đơn hàng</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="list-group list-group-flush rounded-3 overflow-hidden">
                <a href="@Url.Action("Profile", "User")"
                   class="list-group-item list-group-item-action py-3 border-bottom">
                    <i class="fa-solid fa-user me-2 text-muted"></i> Hồ sơ người dùng
                </a>
                <div class="list-group-item bg-danger text-white py-3 border-0 fw-bold">
                    <i class="fa-solid fa-file-invoice me-2"></i> Hoá Đơn Của Bạn
                </div>
                <a href="@Url.Action("FavouriteProductList", "Product")"
                   class="list-group-item list-group-item-action py-3 border-0">
                    <i class="fa-solid fa-heart me-2 text-muted"></i> Sản Phẩm Yêu Thích
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">Đơn hàng của tôi</h4>
            <span class="badge bg-light text-dark border">4 đơn hàng</span>
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-state py-5 text-center">
                <div class="empty-state-icon mb-3">
                    <i class="fa-solid fa-clipboard-list text-primary"
                       style="font-size: 3rem; opacity: 0.7"></i>
                </div>
                <h5 class="text-muted fw-bold">Chưa có đơn hàng nào</h5>
                <p class="text-secondary small">Bạn vẫn chưa thực hiện đơn hàng nào gần đây.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-danger mt-3 px-4">
                    <i class="fa-solid fa-shopping-bag me-2"></i>Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="card border-0 shadow-lg rounded-3 mb-3">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                            <div class="d-flex gap-3">
                                <div class="bg-light rounded p-2 d-flex align-items-center justify-content-center"
                                     style="width: 60px; height: 60px">
                                    <i class="fa-solid fa-box text-danger fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Mã đơn hàng: #@item.MaHoaDon</h6>
                                    <p class="small text-muted mb-0 text-uppercase">Ngày đặt: @item.NgayDatMuaHang.ToShortDateString()</p>
                                </div>
                            </div>
                            <div class="text-md-end">
                                <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary mb-2 px-3 py-2">@item.TrangThaiDonHang</span>
                                <div class="fw-bold text-danger fs-5">@string.Format("{0:#,##0}đ", item.TongTien)</div>
                            </div>
                        </div>
                        <hr class="my-3 opacity-50" />
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <span class="small text-muted"><i class="fa-solid fa-credit-card me-1"></i> @item.PhuongThucThanhToan</span>
                            <a href="@Url.Action("Details", "Bill", new {maHoaDon = item.MaHoaDon})" class="btn btn-outline-danger btn-sm px-4 fw-bold">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>