
@{
    ViewBag.Title = "Liên hệ";
    Layout = "~/Views/Shared/_LayoutPage_Main.cshtml";
}

@section LibraryCSS {
    <link href="@Url.Content("~/assets/css/pages/contact.css")" rel="stylesheet" />
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dark">Trang chủ</a>
        </li>
        <li class="breadcrumb-item active text-danger" aria-current="page">Liên hệ</li>
    </ol>
</nav>

<div class="row g-5">
    <div class="col-md-6">
        <h2 class="fw-bold mb-4">LIÊN HỆ</h2>
        <form action="#" method="post">
            <div class="mb-3">
                <label for="fullName" class="form-label">Họ tên: <span class="text-danger">*</span></label>
                <input type="text"
                       class="form-control"
                       id="fullName"
                       placeholder="Nguyễn Văn A"
                       required />
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email: <span class="text-danger">*</span></label>
                <input type="email"
                       class="form-control"
                       id="email"
                       placeholder="example@domain.com"
                       required />
            </div>
            <div class="mb-3">
                <label for="content" class="form-label">Nội dung: <span class="text-danger">*</span></label>
                <textarea class="form-control"
                          id="content"
                          rows="6"
                          placeholder="Viết nội dung tại đây"></textarea>
            </div>
            <button type="submit" class="btn btn-danger px-5 py-2">Gửi</button>
        </form>
    </div>

    <div class="col-md-6">
        <div class="map-container shadow-sm border rounded overflow-hidden h-100">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d62705.076326429495!2d106.60416901237103!3d10.806159823201295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752be27d8b4f4d%3A0x92dcba2950430867!2sHCMC%20University%20of%20Industry%20and%20Trade!5e0!3m2!1sen!2s!4v1777036528873!5m2!1sen!2s"
                    width="100%"
                    height="100%"
                    style="border: 0; min-height: 450px"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</div>