
@{
    ViewBag.Title = "Từ chối truy cập";
    Layout = null;
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fashion Shop - Thế giới thời trang của bạn</title>
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/assets/icons/icon16.ico")" />
    <link href="@Url.Content("~/lib/bootstrap/css/bootstrap.min.css")"
          rel="stylesheet" />
    <link rel="stylesheet"
          href="@Url.Content("~/lib/font-awesome/css/all.min.css")" />
    <link rel="stylesheet" href="/assets/css/pages/access-denied.css" />
</head>

<body class="bg-light">
    <div class="container d-flex align-items-center justify-content-center min-vh-100">
        <div class="text-center">
            <div class="mb-4">
                <div class="display-1 text-danger">
                    <i class="fa-solid fa-hand-slash animate__animated animate__shakeX"></i>
                </div>
                <h1 class="display-4 fw-bold text-dark">403</h1>
                <h2 class="h4 fw-semibold text-muted text-uppercase">Truy cập bị từ chối</h2>
            </div>

            <div class="card border-0 shadow-sm mx-auto mb-4" style="max-width: 500px">
                <div class="card-body p-4">
                    <p class="text-muted mb-0">
                        Rất tiếc! Bạn không có quyền truy cập vào trang này. Vui lòng liên hệ quản trị viên
                        hoặc quay lại trang chủ.
                    </p>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a href="javascript:history.back()"
                   class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                    <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
                </a>
                <a href="./index.html" class="btn btn-danger px-4 py-2 rounded-pill shadow-sm">
                    <i class="fa-solid fa-house me-2"></i>Trang chủ
                </a>
            </div>

            <p class="mt-5 small text-muted text-uppercase"
               style="letter-spacing: 1px; font-size: 10px">
                Hệ thống bảo mật FashionShop - Dự án học tập
            </p>
        </div>
    </div>
</body>
</html>
