@model IEnumerable<FashionShop.Models.LoaiSanPham>
@{
    var SkipItems = ViewBag.SkipItems as List<FashionShop.Models.LoaiSanPham>;
}
<div class="card border-0 shadow-sm mb-4 rounded-3 overflow-hidden">
    <div class="card-header bg-danger text-white fw-bold py-2">
        <i class="fa-solid fa-bars me-2"></i> Danh mục sản phẩm
    </div>
    <div class="list-group list-group-flush border-top-0" id="categoryList">
        @foreach (var item in Model)
        {
            <a href="@Url.Action("GetInfoAboutProductType", "ProductType", new { maLoaiSanPham = item.MaLoai})"
               class="list-group-item list-group-item-action border-0 border-bottom py-2">
                @item.TenLoai
            </a>
        }

        @if (Model != null && Model.Count() >= 10)
        {
            foreach (var item in SkipItems)
            {
                <div class="collapse" id="moreCategories">
                    <a href="@Url.Action("GetInfoAboutProductType", "ProductType", new { maLoaiSanPham = item.MaLoai })"
                       class="list-group-item list-group-item-action border-0 border-bottom d-flex justify-content-between align-items-center py-2">
                        <span>@item.TenLoai</span>
                        <i class="fa-solid fa-chevron-right small text-muted" style="font-size: 10px"></i>
                    </a>
                </div>
            }
            <button class="btn btn-light w-100 py-2 small text-muted fw-bold border-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#moreCategories"
                    aria-expanded="false">
                XEM THÊM <i class="fa-solid fa-caret-down ms-1"></i>
            </button>
        }
    </div>
</div>
