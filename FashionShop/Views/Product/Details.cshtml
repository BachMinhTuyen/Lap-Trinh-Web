@model FashionShop.Models.SanPham
@{
    ViewBag.Title = "Thông tin sản phẩm";
    Layout = "~/Views/Shared/_LayoutPage_Main.cshtml";

    var BienThe = ViewBag.BienThe as List<FashionShop.Models.BienTheSanPham>;
    var HinhAnh = ViewBag.HinhAnh as List<FashionShop.Models.HinhAnh>;
    var YeuThich = ViewBag.YeuThich as FashionShop.Models.YeuThich;
}
@section LibraryCSS {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link href="@Url.Content("~/assets/css/pages/product-detail.css")" rel="stylesheet" />
}
@section LibraryJS {
    <script src="~/assets/javascript/details.js"></script>
    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const swiper = new Swiper(".productSwiper", {
                loop: true,
                pagination: {
                    el: ".swiper-pagination",
                    clickable: true,
                },
                navigation: {
                    nextEl: ".swiper-button-next",
                    prevEl: ".swiper-button-prev",
                },
                autoplay: {
                    delay: 3000,
                    disableOnInteraction: false,
                },
            });
        });

        document.querySelectorAll(".btn-wishlist").forEach((button) => {
            button.addEventListener("click", function () {
                this.classList.toggle("active");

                const icon = this.querySelector("i");
                if (this.classList.contains("active")) {
                    icon.classList.remove("fa-regular");
                    icon.classList.add("fa-solid");
                } else {
                    icon.classList.remove("fa-solid");
                    icon.classList.add("fa-regular");
                }
            });
        });
    </script>
    @*@if (YeuThich != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                // Sự kiện click yêu thích sản phẩm
                document.querySelector('.icon-liked').addEventListener('click', () => {
                    window.location.href = '/Product/NOTFavouriteProduct?maSanPham=@Model.MaSanPham'
                })
            });
            </script>
        }
        else
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                // Sự kiện click yêu thích sản phẩm
                document.querySelector('.no-liked').addEventListener('click', () => {
                    window.location.href = '/Product/FavouriteProduct?maSanPham=@Model.MaSanPham'
                })
            });
            </script>
        }*@
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-muted">Trang chủ</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("List", "Product")" class="text-decoration-none text-muted">Sản phẩm</a>
        </li>
        <li class="breadcrumb-item active text-danger" aria-current="page">Thông tin sản phẩm</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="product-slider-container position-relative">
            <div class="swiper productSwiper">
                <div class="swiper-wrapper">
                    @foreach (var item in HinhAnh)
                    {
                        <div class="swiper-slide bg-light rounded text-center py-4">
                            <img src="@Url.Content("~/assets/img/")@item.TenHinhAnh" class="img-fluid" alt="@item.TenHinhAnh" />
                        </div>
                    }

                </div>
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-pagination"></div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="product-details ps-lg-4">
            <h2 class="fw-bold mb-2">@Model.TenSanPham</h2>
            <p class="text-muted small mb-3">
                Mã sản phẩm: <span id="product-id" class="fw-bold text-dark">@Model.MaSanPham</span>
            </p>

            <div class="price-section mb-4">
                @if (Model.KhuyenMai != 0)
                {
                    <h3 class="text-danger fw-bold mb-1">@string.Format("{0:#,##0}đ", Model.GiaSanPham - (Model.GiaSanPham * Model.KhuyenMai))</h3>
                }
            <span class="text-muted text-decoration-line-through">@string.Format("{0:#,##0}đ", Model.GiaSanPham)</span>
            </div>

            <div class="mb-3">
                <p class="fw-bold mb-2">
                    Chọn màu sắc: <span class="text-muted fw-normal" id="selected-color">Chưa chọn</span>
                </p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var item in BienThe.Select(s => s.TenMau).Distinct())
                    {
                        <input type="radio" class="btn-check" name="color" id="color-@item.ToLower()" value="@item" autocomplete="off" />
                        <label class="btn btn-outline-dark px-3" for="color-@item.ToLower()">@item</label>
                    }
                </div>
            </div>

            <div class="mb-4">
                <p class="fw-bold mb-2">
                    Chọn size: <span class="text-muted fw-normal" id="selected-size">Chưa chọn</span>
                </p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var item in BienThe.Select(s => s.TenSize).Distinct())
                    {
                        <input type="radio" class="btn-check" name="size" id="size-@item.ToLower()" value="@item" autocomplete="off" />
                        <label class="btn btn-outline-dark px-3" for="size-@item.ToLower()">@item</label>
                    }
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
                <div class="quantity-input input-group" style="width: 130px">
                    <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)">-</button>
                    <input type="text" id="quantityInput" class="form-control text-center" value="1" />
                    <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)">+</button>
                </div>
                <div id="product-config" data-prod-id="@Model.MaSanPham"></div>
                <button id="add-to-cart" class="btn btn-outline-dark px-4 flex-grow-1 py-2">Thêm vào giỏ hàng</button>
                <button id="to-order" class="btn btn-danger px-4 flex-grow-1 py-2 fw-bold">Mua ngay</button>
                <button class="btn btn-light border px-3 py-2 btn-wishlist">
                    @if (YeuThich != null)
                    {
                        <i class="fa-regular fa-heart active"></i>
                    }
                    else
                    {
                        <i class="fa-regular fa-heart"></i>
                    }
                </button>
            </div>
            <div class="mb-4">
                <p class="text-muted small">
                    Còn lại <span class="fw-bold text-dark">50</span> sản phẩm
                </p>
            </div>

            <div class="row g-4 border-top pt-4 mt-2 mb-5">
                <div class="col-12 col-md-4 d-flex align-items-start">
                    <i class="fa-regular fa-clock fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0">Giao hàng nhanh</h6>
                        <p class="small text-muted mb-0">Từ 2 - 5 ngày</p>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-start">
                    <i class="fa-solid fa-truck fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0">Miễn phí vận chuyển</h6>
                        <p class="small text-muted mb-0">Đơn hàng từ 399K</p>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-start">
                    <i class="fa-solid fa-magnifying-glass fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0 text-truncate">Theo dõi đơn hàng</h6>
                        <p class="small text-muted mb-0">Một cách dễ dàng</p>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-start mt-md-4">
                    <i class="fa-solid fa-box-archive fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0">Đổi trả linh hoạt</h6>
                        <p class="small text-muted mb-0">Với sản phẩm không áp dụng khuyến mãi</p>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-start mt-md-4">
                    <i class="fa-solid fa-wallet fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0">Thanh toán dễ dàng</h6>
                        <p class="small text-muted mb-0">Nhiều hình thức</p>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-start mt-md-4">
                    <i class="fa-solid fa-headset fs-4 me-3 text-dark mt-1"></i>
                    <div>
                        <h6 class="fw-bold mb-0">Hotline hỗ trợ</h6>
                        <p class="small text-muted mb-0">0123 456 789</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 border-top pt-4">
    <h4 class="fw-bold mb-4">Mô Tả Sản Phẩm</h4>
    <div class="description-content text-muted lh-lg">
        <p>
            @Model.MoTaSanPham
        </p>
    </div>
</div>
