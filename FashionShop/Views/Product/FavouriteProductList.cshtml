        </script>*@
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-muted">Trang chủ</a>
        </li>
        <li class="breadcrumb-item active text-danger fw-bold">Sản phẩm yêu thích</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-12 col-lg-3">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="list-group list-group-flush rounded-3 overflow-hidden">
                <a href="@Url.Action("Profile", "User")"
                   class="list-group-item list-group-item-action py-3 border-bottom">
                    <i class="fa-solid fa-user me-2 text-muted"></i> Hồ sơ người dùng
                </a>
                <a href="@Url.Action("ViewBills", "Bill", new { UserName = ViewBag.UserName})"
                   class="list-group-item list-group-item-action py-3 border-bottom">
                    <i class="fa-solid fa-file-invoice me-2 text-muted"></i> Hoá Đơn Của Bạn
                </a>
                <div class="list-group-item bg-danger text-white py-3 border-0 fw-bold">
                    <i class="fa-solid fa-heart me-2"></i> Sản Phẩm Yêu Thích
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-9">
        <h4 class="fw-bold mb-4">Sản phẩm đã thích</h4>

        <div class="row g-2">
            @if (@Model.Count != 0)
            {
                foreach (var item in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3 mb-4">
                        <div class="card h-100 border-0 shadow-lg rounded position-relative overflow-hidden product-card">
                            <button class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle shadow-sm text-danger"
                                    style="z-index: 2; width: 30px; height: 30px; padding: 0"
                                    title="Xóa khỏi danh sách">
                                <i class="fa-solid fa-xmark" style="font-size: 0.8rem"></i>
                            </button>

                            <a href="@Url.Action("Details", "Product", new { maSanPham = item.SanPham.MaSanPham})"
                               class="text-decoration-none h-100 d-flex flex-column">
                                <div class="text-center p-2 bg-light">
                                    <img src="@Url.Content("~/assets/img/")@item.SanPham.AnhDaiDien"
                                         class="img-fluid"
                                         alt="@item.SanPham.TenSanPham"
                                         style="height: 180px; object-fit: contain" />
                                </div>

                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="text-dark fw-bold mb-1 text-truncate" style="font-size: 0.9rem">
                                        @item.SanPham.TenSanPham
                                    </h6>

                                    @if (item.SanPham.KhuyenMai != 0)
                                    {
                                        <div class="text-danger fw-bold mb-0" style="font-size: 1rem">@string.Format("{0:#,##0}đ", item.SanPham.GiaSanPham - (item.SanPham.GiaSanPham * item.SanPham.KhuyenMai))</div>
                                    }
                                    <div class="text-muted small text-decoration-line-through mb-2"
                                         style="font-size: 0.8rem">
                                        @string.Format("{0:#,##0đ}đ", item.SanPham.GiaSanPham)
                                    </div>

                                    <div class="mt-auto text-warning" style="font-size: 0.75rem">
                                        <i class="fa-solid fa-star"></i>
                                        <i class="fa-solid fa-star"></i>
                                        <i class="fa-solid fa-star"></i>
                                        <i class="fa-solid fa-star"></i>
                                        <i class="fa-regular fa-star"></i>
                                        <span class="text-muted ms-1">(24)</span>
                                    </div>
                                </div>
                            </a>

                            <div class="card-footer bg-white border-0 p-3 pt-0">
                                <button class="btn btn-danger w-100 fw-bold py-2 btn-sm">
                                    <i class="fa-solid fa-cart-shopping me-1"></i> MUA NGAY
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link border-0 bg-light me-2 rounded text-dark px-3" href="#">Prev</a>
                        </li>
                        @for (int i = 0; i < ViewBag.NoOfPages; i++)
                        {
                            if ((i + 1) == ViewBag.Page)
                            {
                                <li class="page-item active">
                                    <a class="page-link border-0 bg-danger me-2 rounded px-3" href="@Url.Action("List", "Product", new { page = (i + 1)})">@(i+1)</a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link border-0 bg-white text-dark me-2 rounded shadow-sm px-3"
                                       href="@Url.Action("List", "Product", new { page = (i + 1)})">@(i+1)</a>
                                </li>
                            }
                        }
                        <li class="page-item">
                            <a class="page-link border-0 bg-white text-dark rounded shadow-sm px-3" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            }
            else
            {
                <div class="empty-state text-center py-5 w-100">
                    <div class="mb-4">
                        <i class="fa-solid fa-box-open text-muted" style="font-size: 80px; opacity: 0.3;"></i>
                    </div>
                    <h4 class="fw-bold">Ôi, không tìm thấy sản phẩm yêu thích nào!</h4>
                    <p class="text-muted">Có vẻ như bạn vẫn chưa có thêm sản phẩm yêu thích.</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-danger rounded-pill px-4 mt-3">
                        Hãy chọn sản phẩm yêu thích ngay
                    </a>
                </div>
            }
        </div>
    </div>
</div>